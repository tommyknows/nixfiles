;; ---------------------------------------------------------------------------
;; Machine-Local Overrides (ramon)
;; Appended after all built-in Safehouse profiles via --append-profile.
;; Later rules win, so anything here can broaden OR narrow earlier policy.
;; Source: programs/claude/local-overrides.sb (managed by nix)
;; ---------------------------------------------------------------------------

;; -- Nix store / system + user profiles -----------------------------------
;; nix-darwin and home-manager install every binary under /nix/store and
;; expose them through symlink profiles. Without these grants, `exec()` of
;; any nix-managed tool (claude, git, node, …) fails to resolve through the
;; symlink chain (~/.nix-profile -> ~/.local/state/nix/profiles/profile ->
;; /nix/store/<hash>-...) and PATH lookup returns ENOENT.
;;
;; /etc/static is nix-darwin's mechanism for exposing system config under /etc
;; (~/etc/ssh/sshd_config, ~/etc/ssl/certs/ca-certificates.crt, etc.) as
;; symlinks into the nix store. Without read access to it, e.g. nix-built Node
;; can't resolve /etc/ssl/certs/ca-certificates.crt -> /etc/static/... and TLS
;; handshakes fail with UNABLE_TO_GET_ISSUER_CERT_LOCALLY.

(allow file-read-metadata
    (literal "/nix")                                                ;; Ancestor traversal toward /nix/store.
    (literal "/run")                                                ;; Ancestor traversal toward /run/current-system.
    (literal "/etc/static")                                         ;; nix-darwin static-files symlink (target lives in /nix/store).
    (literal "/private/etc/static")                                 ;; macOS realpath form of /etc/static.
    (home-literal "/.local/state")                                  ;; Ancestor traversal toward ~/.local/state/nix.
)

(allow file-read*
    (subpath "/nix/store")                                          ;; All nix-installed binaries and their dynamic library dependencies (content-addressed, world-readable by design).
    (subpath "/run/current-system")                                 ;; nix-darwin active system profile (system-wide binaries and config).
    (subpath "/etc/static")                                         ;; nix-managed /etc files (CA bundles, ssh config, …) via static-symlink layer.
    (subpath "/private/etc/static")                                 ;; macOS realpath form of /etc/static.
    (home-subpath "/.nix-profile")                                  ;; home-manager user profile entry point (symlinks into /nix/store).
    (home-subpath "/.local/state/nix")                              ;; Underlying nix profiles directory targeted by ~/.nix-profile.
)

;; -- Fish shell config / state -------------------------------------------
;; ~/.config/fish is a symlink chain into /nix/store managed by home-manager;
;; without read access here, fish can't load user functions (c, w,
;; prepare-subagent, …) so worktree management from inside the sandbox is
;; impossible. Read on /nix/store is already granted, so this is effectively
;; the same exposure as the existing nix store grant.
;;
;; ~/.local/share/fish holds fish_history and generated_completions/. Granting
;; r/w lets sandboxed fish sessions read and append to the shared history. The
;; macOS sandbox has no append-only primitive, so this is full r/w — accepted
;; on the basis that command history is not where this user stores secrets
;; (tokens go through env files / Secretive / 1Password, not inline args).

(allow file-read-metadata
    (home-literal "/.config")                                       ;; Ancestor traversal toward fish config.
    (home-literal "/.local")                                        ;; Ancestor traversal toward fish state.
    (home-literal "/.local/share")                                  ;; Ancestor traversal toward fish state.
)

(allow file-read*
    (home-subpath "/.config/fish")                                  ;; fish config, functions, abbrs, completions (symlinks into /nix/store).
)

(allow file-read* file-write*
    (home-subpath "/.local/share/fish")                             ;; fish history + generated_completions cache.
)

;; -- Jujutsu (jj) config + central repo state -----------------------------
;; ~/.config/jj holds config.toml (a home-manager symlink into /nix/store) and
;; repos/<hash>/ — jj's central per-repo metadata (e.g. metadata.binpb), which
;; jj reads AND writes on essentially every command. Without write access here,
;; jj fails with "Operation not permitted" on .../metadata.binpb, so worktree
;; management (c/w/bd → jj workspaces) and every jj command break in the sandbox.
;; Safehouse ships no jj profile, so we grant it here. config.toml's target is
;; read-only in /nix/store (already granted); only repos/ is mutated, and it's
;; jj bookkeeping — not a secret store (cf. the fish-history rationale above).
;; ~/.config ancestor traversal is already granted in the fish section above.

(allow file-read*
    (home-subpath "/.config/jj")                                    ;; config.toml (symlink into /nix/store) + dir listing.
)

(allow file-read* file-write*
    (home-subpath "/.config/jj/repos")                              ;; jj central per-repo metadata (metadata.binpb, op-store pointers).
)

;; -- Nix daemon (for nix-shell -p / nix run nixpkgs#…) --------------------
;; The nix-daemon protocol lets clients realise derivations, query the store,
;; and trigger downloads from substituters. Granting socket access enables
;; ad-hoc tooling like `nix-shell -p <pkg>` and `nix run nixpkgs#<pkg>` from
;; inside the sandbox.
;;
;; Trust boundary: the daemon runs as root, but its protocol does NOT expose
;; system mutation operations — no /etc writes, no profile switch, no launchd
;; modification. `darwin-rebuild switch` uses a separate sudo activation
;; script, not the daemon protocol, so this grant cannot swap the active
;; system. Builds run as `nixbld*` users inside the daemon's own build
;; sandbox (/private/tmp/nix-build-*), so derivation execution is real code
;; execution but isolated from our user account. Profile mutation
;; (`nix profile install …`) is blocked separately by the read-only grant on
;; ~/.local/state/nix above.
;;
;; New risks added by this grant: arbitrary nixpkgs downloads (unbounded
;; disk) and supply-chain exposure to substituters — the same risks accepted
;; on every `rebuild`.

(allow file-read-metadata
    (literal "/nix/var")                                            ;; Ancestor traversal toward daemon socket.
    (literal "/nix/var/nix")                                        ;; Ancestor traversal toward daemon socket.
    (literal "/nix/var/nix/daemon-socket")                          ;; Ancestor traversal toward daemon socket.
    (home-literal "/.cache")                                        ;; Ancestor traversal toward nix client caches.
)

(allow file-read*
    (literal "/nix/var/nix/daemon-socket/socket")                   ;; Socket file metadata + open() before connect().
)

(allow network-outbound
    (remote unix-socket
        (literal "/nix/var/nix/daemon-socket/socket")
    )
)

(allow file-read* file-write*
    (home-subpath "/.cache/nix")                                    ;; nix client-side eval / fetcher caches consulted on `nix-shell` startup.
)

;; -- Determinate nix: CLI exec + config read ------------------------------
;; Determinate installs the nix CLI at /nix/var/nix/profiles/default/bin/nix
;; and there is NO nix under ~/.nix-profile. Without read on the profiles tree,
;; exec() of that path fails at the profile-symlink hop, `nix` resolves to
;; ENOENT, and every attempt to run it dies with "operation not permitted: nix".
;; This also breaks determinate-nixd, which shells out to `nix config show`.
;; So this grant is what actually makes the nix-daemon socket grant above
;; usable: `nix flake check` / `nix eval …drvPath` / `nix build` /
;; `nix store prefetch-file` all have to exec nix first. (The store targets the
;; profile symlinks point at are already covered by the /nix/store grant.)
;;
;; /etc/nix holds nix.conf, nix.custom.conf and any netrc-file, which nix and
;; determinate-nixd read on startup. /etc -> /private/etc on macOS, so both
;; forms are granted (cf. the /etc/static pair above).

(allow file-read-metadata
    (literal "/etc")                                                ;; Ancestor traversal toward /etc/nix.
    (literal "/private/etc")                                        ;; macOS realpath form.
)

(allow file-read*
    (subpath "/nix/var/nix/profiles")                               ;; Determinate nix CLI + per-user profiles (symlinks into /nix/store).
    (subpath "/etc/nix")                                            ;; nix.conf, nix.custom.conf, netrc-file.
    (subpath "/private/etc/nix")                                    ;; macOS realpath form.
)

;; NIX_PATH / `<nixpkgs>` lookup entries. nix's built-in `nix-path` default
;; still lists $HOME/.nix-defexpr/channels even when NIX_PATH is empty, so an
;; `--impure` eval that resolves `<nixpkgs>` stats these. They exist here but
;; are denied by default → EPERM (not a clean ENOENT), which aborts the eval
;; ("Operation not permitted"). Grant read so ad-hoc impure evals work; content
;; is just nix expressions / channel symlinks into /nix/store (already readable),
;; same exposure class as the profiles grant above. (Locked flakerefs avoid the
;; lookup entirely and remain the right habit for reproducible builds.)
(allow file-read*
    (home-subpath "/.nix-defexpr")                                  ;; channel / default-expr lookup path in the nix-path default.
    (home-subpath "/.nixpkgs")                                      ;; legacy user nixpkgs override path.
)

;; -- rtk state ------------------------------------------------------------
;; rtk (token-killing proxy hooked into claude via PreToolUse) persists its
;; sqlite tracking DB, hook-warn rate-limit timestamp, and `tee` output dumps
;; under ~/Library/Application Support/rtk/. Without write access here, rtk
;; fails to initialize its DB and the rate-limit timestamp can't update, so
;; the "No hook installed" warning fires on every command instead of once
;; per day.

(allow file-read-metadata
    (home-literal "/Library/Application Support")                   ;; Ancestor traversal toward rtk state dir.
)

(allow file-read* file-write*
    (home-subpath "/Library/Application Support/rtk")               ;; rtk state: history.db, .hook_warn_last, tee/.
)

;; -- Secretive SSH agent ----------------------------------------------------
;; Secretive stores its socket and public keys under
;; ~/Library/Containers/com.maxgoedjen.Secretive.SecretAgent/Data/, which is
;; outside the paths covered by Safehouse's --enable=ssh profile.
;; Required for:
;;   - SSH-format commit signing (gpg.format=ssh, commit.gpgsign=true)
;;   - SSH-based git remote operations (fetch/push)
;; Secretive prompts on the user's screen for every signature use, so this
;; grant does not give the sandbox unattended key access.

(allow file-read-metadata
    (home-literal "/Library")                                       ;; Ancestor traversal toward the Secretive container.
    (home-literal "/Library/Containers")                            ;; Ancestor traversal toward the Secretive container.
    (home-literal "/Library/Containers/com.maxgoedjen.Secretive.SecretAgent")
    (home-literal "/Library/Containers/com.maxgoedjen.Secretive.SecretAgent/Data")
)

(allow file-read*
    (home-literal "/Library/Containers/com.maxgoedjen.Secretive.SecretAgent/Data/socket.ssh")  ;; Socket file metadata + open() before connect().
    (home-subpath "/Library/Containers/com.maxgoedjen.Secretive.SecretAgent/Data/PublicKeys")  ;; Public key files referenced by user.signingkey.
)

(allow network-outbound
    (remote unix-socket
        (path-regex (string-append "^" HOME_DIR "/Library/Containers/com\\.maxgoedjen\\.Secretive\\.SecretAgent/Data/socket\\.ssh$"))
    )
)

;; -- tilt state -----------------------------------------------------------
;; tilt persists its local config, analytics opt-in, and per-project state
;; under ~/.tilt-dev/. Without write access here, `tilt up`/`tilt ci` aborts
;; during initialization when it tries to create token/analytics files.
;; Docker and Kubernetes access remain gated by --enable=docker/--enable=kubectl.

(allow file-read-metadata
    (home-literal "/.tilt-dev")                                     ;; Ancestor traversal toward tilt state dir.
    (home-literal "/Library/Caches")                                ;; Ancestor traversal toward macOS-style cache dir below.
    (home-literal "/Library/Preferences")                           ;; Ancestor traversal toward macOS-style prefs dir below.
)

(allow file-read* file-write*
    (home-subpath "/.tilt-dev")                                     ;; tilt state: config, analytics, token, per-project caches.
    (home-subpath "/Library/Caches/tilt-dev")                       ;; tilt build/image/api cache (macOS XDG_CACHE_HOME location).
    (home-subpath "/Library/Application Support/tilt-dev")          ;; tilt persistent state (macOS XDG_DATA_HOME location).
    (home-subpath "/Library/Preferences/astro")                     ;; tilt-dev/wmclient telemetry preferences (stored under "astro").
)

;; -- OrbStack bundled CLIs ------------------------------------------------
;; Safehouse's --enable=docker profile grants the Orbstack daemon socket and
;; the app's completions dir, but NOT the bundled CLI binaries under
;; /Applications/OrbStack.app/Contents/MacOS/xbin. /usr/local/bin/docker is
;; a symlink into that path; PATH lookups hit a sandbox deny on the target
;; and child processes exit 127 ("docker: command not found"). Tilt builds
;; rely on `docker` (and sometimes `buildx`) being callable, so grant read
;; on the xbin dir. Frameworks/ is included because OrbStack's CLIs are
;; dynamically linked against dylibs shipped there.

(allow file-read*
    (subpath "/Applications/OrbStack.app/Contents/MacOS/xbin")      ;; docker, kubectl, helm, buildx — OrbStack-bundled CLIs.
    (subpath "/Applications/OrbStack.app/Contents/Frameworks")      ;; Shared libraries the bundled CLIs link against.
)

;; -- Scoped kubeconfig (tilt/k8s) -----------------------------------------
;; When `cl` detects a Tiltfile in the active worktree it appends
;; `--enable=docker --env-pass=KUBECONFIG` and sets KUBECONFIG to the file
;; below. We intentionally do NOT use safehouse's --enable=kubectl, which
;; would expose all of ~/.kube and ~/.krew — instead we whitelist exactly
;; one kubeconfig file. That file should inline CA, client cert, and client
;; key as *-data fields so this single read grant is the only credential
;; surface in the sandbox.
;;
;; Apiserver network access rides on safehouse's wide-open 20-network
;; baseline; for a local cluster (Orbstack/Docker Desktop) traffic stays
;; on 127.0.0.1. Cache writes below are not sensitive — they hold the
;; discovery/HTTP response cache kubectl maintains across runs.

(allow file-read-metadata
    (home-literal "/.kube")                                         ;; Ancestor traversal toward configs/ and cache dirs.
    (home-literal "/.kube/configs")                                 ;; Ancestor traversal toward the scoped kubeconfig file.
)

(allow file-read*
    (home-literal "/.kube/configs/tilt")                            ;; Scoped single-context kubeconfig consumed via KUBECONFIG.
)

(allow file-read* file-write*
    (home-subpath "/.kube/cache")                                   ;; kubectl discovery cache (group/version metadata).
    (home-subpath "/.kube/http-cache")                              ;; kubectl HTTP response cache.
)

;; -- tmux IPC socket ------------------------------------------------------
;; tmux client commands (e.g. `tmux set-option`) communicate with the tmux
;; server via a UNIX socket under $TMPDIR/tmux-<uid>/default. Used by the
;; SessionStart hook to stamp the active session id onto the current pane
;; (consumed by title.sh and vim's claude-ask plugin). $TMPDIR on macOS is
;; per-user under /var/folders/<hash>/T/, so we match by regex.

(allow file-read-metadata
    (regex #"^/private/var/folders/[^/]+/T/tmux-[0-9]+$")
    (regex #"^/var/folders/[^/]+/T/tmux-[0-9]+$")
)

(allow file-read* file-write*
    (regex #"^/private/var/folders/[^/]+/T/tmux-[0-9]+/.*$")
    (regex #"^/var/folders/[^/]+/T/tmux-[0-9]+/.*$")
)

(allow network-outbound
    (remote unix-socket
        (path-regex #"^/private/var/folders/[^/]+/T/tmux-[0-9]+/default$")
    )
)

;; -- Go env (read-only) ---------------------------------------------------
;; home-manager's `programs.go.env` writes ~/Library/Application Support/go/env
;; on macOS (Go's native config location there, not ~/.config/go/env). Without
;; read access, `go build` inside the sandbox loses GOFLAGS=-buildvcs=false and
;; hits the bare-clone+worktree VCS detection bug (Go walks past the worktree's
;; .git *file* and lands at the bare .git/ directory → `git status` exits 128).

(allow file-read*
    (home-subpath "/Library/Application Support/go")                ;; go env file (GOPATH, GOFLAGS, …).
)

;; -- staticcheck cache ----------------------------------------------------
;; staticcheck (honnef.co/go/tools) caches package analysis results via
;; os.UserCacheDir() → ~/Library/Caches/staticcheck on macOS. Without write
;; access the linter either falls back to a full re-analysis on every run
;; (very slow on large modules) or aborts when it can't persist its cache.
;; Note: ~/Library/Caches ancestor traversal is already granted in the tilt
;; section above; only the subpath grant is needed here.

(allow file-read* file-write*
    (home-subpath "/Library/Caches/staticcheck")                    ;; staticcheck package analysis cache.
)

;; -- ic CLI state (read-only) ---------------------------------------------
;; The work-internal `ic` CLI caches its GitHub token under ~/.ic/. Sandboxed
;; tools (e.g. claude invoking `ic ...`) need to *read* the cached token but
;; should never mutate it — token refresh happens in unsandboxed shells.
;; LocateGithubToken does a MkdirAll on ~/.ic before reading; granting
;; read-metadata on the dir lets that no-op succeed when the dir already
;; exists (created outside the sandbox).

(allow file-read-metadata
    (home-literal "/.ic")                                           ;; MkdirAll's stat() before it short-circuits on existing dir.
)

(allow file-read*
    (home-subpath "/.ic")                                           ;; ic CLI state: GitHub token cache.
)

;; -- Clipboard image paste (pasteboard mach service) ----------------------
;; Claude Code's macOS image paste (ctrl-v) shells out to
;;   osascript -e 'the clipboard as «class PNGf»'
;; to detect and extract a clipboard image. osascript itself launches fine
;; (its CoreServices/LaunchServices mach deps are in the base allow-list), but
;; reading NSPasteboard requires the pasteboard server's mach service
;; com.apple.pasteboard.1. Safehouse only grants that inside its OPTIONAL
;; chromium-full integration profile, so a normal `cl` session has it denied
;; by the base `(deny default)` — the AppleScript errors and Claude reports
;; "No image found in clipboard. Use ctrl-v to paste images" even when an
;; image is on the clipboard (which is why `--no-sandbox` works).
;;
;; Trust boundary: this exposes read of the shared system clipboard to the
;; sandbox. Accepted — the clipboard is user-facing scratch space, the same
;; content is already reachable by any unsandboxed process, and pasting into
;; the agent is the explicit intent here.

(allow mach-lookup
    (global-name "com.apple.pasteboard.1")                          ;; NSPasteboard server, for osascript clipboard image extraction.
)

;; -- Explicit denies (belt-and-suspenders) ---------------------------------
;; These paths are already covered by Safehouse's deny-by-default baseline.
;; The explicit denies here guarantee they stay denied even if a future
;; --enable=<feature> or --add-dirs grant inadvertently broadens access.

(deny file-read* file-write*
    (home-subpath "/.aws")                                          ;; AWS credentials/config; would be opened by --enable=cloud-credentials.
    (home-subpath "/.gnupg")                                        ;; GPG keyring (unused by current signing setup, but block anyway).
    (home-subpath "/.ollama")                                       ;; Local model state and API config.
    (home-subpath "/.terraform.d")                                  ;; Terraform Cloud credentials (credentials.tfrc.json).
)
