{
  "cSpell.enabled": false,
  "cSpell.userWords": [
    "CPEs",
    "Serializers",
    "distro",
    "elems",
    "godoc",
    "monokai",
    "pino",
    "recognise",
    "resliced",
    "serialisers",
    "structs",
    "unbuffered",
    "vuln",
    "vulns"
  ],
  "typescript.format.enabled": true,
  "coc.preferences.bracketEnterImprove": true,
  "coc.preferences.formatOnSave": true,
  "prettier.disableLanguages": [
    // I'm surprised this works??
    // But it seems to also not touch yaml anymore (which might be fine too.)
    "helm",
    "shell",
    // prose reflow swallows/rejoins lines on save — keep markdown untouched
    "markdown"
  ],
  "git.addedSign.text": "▎",
  "git.changedSign.text": "▎",
  "git.removedSign.text": "▎",
  "git.topRemovedSign.text": "▔",
  "git.changeRemovedSign.text": "▎",
  "yaml.schemaStore.enable": true,
  "yaml.schemas": {
    "kubernetes": "*.yaml",
    "http://json.schemastore.org/github-workflow": ".github/workflows/*",
    "http://json.schemastore.org/github-action": ".github/action.{yml,yaml}",
    "http://json.schemastore.org/prettierrc": ".prettierrc.{yml,yaml}",
    "http://json.schemastore.org/kustomization": "kustomization.{yml,yaml}",
    "http://json.schemastore.org/chart": "Chart.{yml,yaml}",
    "https://raw.githubusercontent.com/compose-spec/compose-spec/master/schema/compose-spec.json": "*docker-compose*.{yml,yaml}"
  },
  "tslint.autoFixOnSave": true,
  "diagnostic-languageserver.filetypes": {
    // lint `sh` (includes `bash`) files
    "sh": "shellcheck"
  },
  "diagnostic-languageserver.formatFiletypes": {
    // format `sh` (includes `bash`) files using formatter defined below
    "sh": "shfmt"
  },
  "diagnostic-languageserver.formatters": {
    // define our formatter so that we can reference it from
    // `diagnostic-languageserver.formatFiletypes`
    "shfmt": {
      "command": "shfmt"
    }
  },
  "languageserver": {
    // gopls needs to be *compiled* with a specific Go version to support its features,
    // so we pin to the nix-installed binary (built against the Go in unstable) rather
    // than whatever `gopls` resolves to on $PATH.
    "gopls": {
      "command": "/Users/ramon/.nix-profile/bin/gopls",
      "filetypes": ["go", "gomod", "gosum"],
      "rootPatterns": ["go.mod", ".git"],
      "initializationOptions": {
        "completeUnimported": true,
        "buildFlags": ["-tags=integration,e2e"]
      }
    },
    "tsserver": {
      "command": "/Users/ramon/.nix-profile/bin/typescript-language-server",
      "args": ["--stdio"],
      "filetypes": [
        "javascript",
        "javascriptreact",
        "javascript.jsx",
        "typescript",
        "typescriptreact",
        "typescript.tsx"
      ],
      "rootPatterns": ["tsconfig.json", "jsconfig.json", "package.json", ".git"],
      "initializationOptions": {
        "tsserver": {
          "path": "/Users/ramon/.nix-profile/bin/tsserver"
        }
      }
    },
    "terraform": {
      "command": "terraform-ls",
      "args": ["serve"],
      "filetypes": ["terraform", "tf"],
      "initializationOptions": {},
      "settings": {}
    },
    "tiltfile": {
      "command": "tilt",
      "args": ["lsp", "start", "--verbose"],
      "filetypes": ["tiltfile"],
      "rootPatterns": [".git"]
    },
    "fish-lsp": {
      "command": "fish-lsp",
      "filetypes": ["fish"],
      "args": ["start"]
    },
    "helm": {
      "command": "helm_ls",
      "args": ["serve"],
      "filetypes": ["helm"],
      "rootPatterns": ["Chart.yaml"],
      "settings": {
        "helm-ls": {
          "valuesFiles": {
            "additionalValuesFilesGlobPattern": "*.yaml"
          }
        }
      }
    },
    "nix": {
      "command": "nil",
      "filetypes": ["nix"],
      "rootPatterns": ["flake.nix"],
      "settings": {
        "nil": {
          "semanticTokens": { "filetypes": ["nix"] },
          "formatting": { "command": ["alejandra"] }
        }
      }
    }
  }
}
